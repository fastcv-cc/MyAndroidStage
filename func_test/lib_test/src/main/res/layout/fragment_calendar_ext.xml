<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Calendar 扩展测试"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <!-- 获取所有信息 -->
            <Button
                android:id="@+id/bt_test_all_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="获取所有日期时间信息"
                android:backgroundTint="#4CAF50"
                tools:ignore="HardcodedText" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#E0E0E0" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="单项测试"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- 获取年份 -->
            <Button
                android:id="@+id/bt_test_year"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="获取年份 (getYearExt)"
                tools:ignore="HardcodedText" />

            <!-- 获取月份 -->
            <Button
                android:id="@+id/bt_test_month"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="获取月份 (getMonthExt)"
                tools:ignore="HardcodedText" />

            <!-- 获取日期 -->
            <Button
                android:id="@+id/bt_test_day"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="获取日期 (getDayExt)"
                tools:ignore="HardcodedText" />

            <!-- 获取小时 -->
            <Button
                android:id="@+id/bt_test_hour"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="获取小时 (getHourExt)"
                tools:ignore="HardcodedText" />

            <!-- 获取分钟 -->
            <Button
                android:id="@+id/bt_test_minute"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="获取分钟 (getMinuteExt)"
                tools:ignore="HardcodedText" />

            <!-- 获取秒数 -->
            <Button
                android:id="@+id/bt_test_second"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="获取秒数 (getSecondExt)"
                tools:ignore="HardcodedText" />

            <!-- 判断上午/下午 -->
            <Button
                android:id="@+id/bt_test_am_pm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="判断上午/下午 (isAMExt)"
                tools:ignore="HardcodedText" />

            <!-- 获取星期索引 -->
            <Button
                android:id="@+id/bt_test_week_index"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="获取星期索引 (getWeekIndexExt)"
                tools:ignore="HardcodedText" />

            <!-- 格式化日期 -->
            <Button
                android:id="@+id/bt_test_format"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="格式化日期 (formatExt)"
                tools:ignore="HardcodedText" />

            <!-- 判断是否同一天 -->
            <Button
                android:id="@+id/bt_test_same_day"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="判断是否同一天 (isSameDayExt)"
                tools:ignore="HardcodedText" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- 结果显示区域 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:elevation="4dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="200dp">

            <TextView
                android:id="@+id/tv_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="100dp"
                android:padding="16dp"
                android:text="测试结果将显示在这里"
                android:textColor="#333333"
                android:textSize="14sp"
                tools:ignore="HardcodedText" />

        </ScrollView>

    </androidx.cardview.widget.CardView>

</LinearLayout>
