<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Context 扩展测试"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <!-- 获取所有信息 -->
            <Button
                android:id="@+id/bt_test_all_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="获取所有基本信息"
                android:backgroundTint="#4CAF50"
                tools:ignore="HardcodedText" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#E0E0E0" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="单位转换测试"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- dp/px 转换 -->
            <Button
                android:id="@+id/bt_test_dp_px"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="dp/px 转换 (dip2pxExt, px2dpExt)"
                tools:ignore="HardcodedText" />

            <!-- sp/px 转换 -->
            <Button
                android:id="@+id/bt_test_sp_px"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="sp/px 转换 (sp2pxExt, px2spExt)"
                tools:ignore="HardcodedText" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#E0E0E0" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="系统信息测试"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- 获取语言 -->
            <Button
                android:id="@+id/bt_test_language"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="获取语言 (getLocaleLanguageExt)"
                tools:ignore="HardcodedText" />

            <!-- 获取国家码 -->
            <Button
                android:id="@+id/bt_test_country"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="获取国家码 (getCountryZipCodeExt)"
                tools:ignore="HardcodedText" />

            <!-- 获取版本信息 -->
            <Button
                android:id="@+id/bt_test_version"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="获取版本信息 (getVersionNameExt, getVersionCodeExt)"
                tools:ignore="HardcodedText" />

            <!-- 获取设备ID -->
            <Button
                android:id="@+id/bt_test_device_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="获取设备ID (getDeviceIdentifierExt)"
                tools:ignore="HardcodedText" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#E0E0E0" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="设备状态测试"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- GPS 状态 -->
            <Button
                android:id="@+id/bt_test_gps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="GPS 状态 (obtainGPSSwitchStatusExt)"
                tools:ignore="HardcodedText" />

            <!-- 蓝牙状态 -->
            <Button
                android:id="@+id/bt_test_bluetooth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="蓝牙状态 (obtainBluetoothSwitchStatusExt)"
                tools:ignore="HardcodedText" />

            <!-- 通知权限状态 -->
            <Button
                android:id="@+id/bt_test_notification"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="通知权限状态 (isNotificationEnabledExt)"
                tools:ignore="HardcodedText" />

            <!-- 通知监听服务状态 -->
            <Button
                android:id="@+id/bt_test_notification_listener"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="通知监听服务状态 (getNotificationListenerServerStatusExt)"
                tools:ignore="HardcodedText" />

            <!-- 打开通知监听授权页面 -->
            <Button
                android:id="@+id/bt_open_notification_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="打开通知监听授权页面"
                android:backgroundTint="#FF9800"
                tools:ignore="HardcodedText" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- 结果显示区域 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:elevation="4dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="200dp">

            <TextView
                android:id="@+id/tv_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="100dp"
                android:padding="16dp"
                android:text="测试结果将显示在这里"
                android:textColor="#333333"
                android:textSize="14sp"
                tools:ignore="HardcodedText" />

        </ScrollView>

    </androidx.cardview.widget.CardView>

</LinearLayout>
