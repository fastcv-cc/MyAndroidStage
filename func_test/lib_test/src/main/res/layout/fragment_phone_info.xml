<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="手机信息工具测试"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <!-- 获取所有信息 -->
            <Button
                android:id="@+id/bt_get_all_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="获取所有设备信息"
                android:backgroundTint="#4CAF50"
                tools:ignore="HardcodedText" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#E0E0E0" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="单项测试"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- Android 版本 -->
            <Button
                android:id="@+id/bt_get_version"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="获取 Android 版本"
                tools:ignore="HardcodedText" />

            <!-- 手机厂商 -->
            <Button
                android:id="@+id/bt_get_manufacturer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="获取手机厂商"
                tools:ignore="HardcodedText" />

            <!-- 手机品牌 -->
            <Button
                android:id="@+id/bt_get_product"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="获取手机品牌"
                tools:ignore="HardcodedText" />

            <!-- 设备型号 -->
            <Button
                android:id="@+id/bt_get_model"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="获取设备型号"
                tools:ignore="HardcodedText" />

            <!-- 设备名称 -->
            <Button
                android:id="@+id/bt_get_device"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="获取设备名称"
                tools:ignore="HardcodedText" />

            <!-- 显示信息 -->
            <Button
                android:id="@+id/bt_get_display"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="获取显示信息"
                tools:ignore="HardcodedText" />

            <!-- CPU 架构 -->
            <Button
                android:id="@+id/bt_get_abis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="获取 CPU 架构"
                tools:ignore="HardcodedText" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- 结果显示区域 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:elevation="4dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="200dp">

            <TextView
                android:id="@+id/tv_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="100dp"
                android:padding="16dp"
                android:text="测试结果将显示在这里"
                android:textColor="#333333"
                android:textSize="14sp"
                tools:ignore="HardcodedText" />

        </ScrollView>

    </androidx.cardview.widget.CardView>

</LinearLayout>
