<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="View 扩展测试 - 防抖点击"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="clickWithTrigger 扩展函数用于防止按钮连击"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="16dp"
                android:textColor="#666666" />

            <!-- 测试1：默认延迟 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. 默认延迟测试 (500ms)"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/bt_test_default_delay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="点击测试默认延迟"
                android:backgroundTint="#4CAF50"
                tools:ignore="HardcodedText" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#E0E0E0" />

            <!-- 测试2：自定义延迟 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="2. 自定义延迟测试"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/ed_delay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="输入延迟时间（毫秒）"
                android:inputType="number"
                android:text="1000"
                tools:ignore="Autofill,HardcodedText" />

            <Button
                android:id="@+id/bt_test_custom_delay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="设置自定义延迟"
                tools:ignore="HardcodedText" />

            <Button
                android:id="@+id/bt_click_test"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="测试按钮（点击此按钮测试）"
                android:backgroundTint="#2196F3"
                tools:ignore="HardcodedText" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#E0E0E0" />

            <!-- 测试3：对比测试 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="3. 对比测试"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/bt_normal_click"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="普通点击（无防抖）"
                android:backgroundTint="#F44336"
                tools:ignore="HardcodedText" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#E0E0E0" />

            <!-- 测试4：不同延迟时间 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="4. 不同延迟时间测试"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/bt_short_delay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="短延迟 (100ms)"
                tools:ignore="HardcodedText" />

            <Button
                android:id="@+id/bt_long_delay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="长延迟 (2000ms)"
                tools:ignore="HardcodedText" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#E0E0E0" />

            <!-- 重置按钮 -->
            <Button
                android:id="@+id/bt_reset"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="重置计数器"
                android:backgroundTint="#9E9E9E"
                tools:ignore="HardcodedText" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- 结果显示区域 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:elevation="4dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="200dp">

            <TextView
                android:id="@+id/tv_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="100dp"
                android:padding="16dp"
                android:text="测试结果将显示在这里"
                android:textColor="#333333"
                android:textSize="14sp"
                tools:ignore="HardcodedText" />

        </ScrollView>

    </androidx.cardview.widget.CardView>

</LinearLayout>
