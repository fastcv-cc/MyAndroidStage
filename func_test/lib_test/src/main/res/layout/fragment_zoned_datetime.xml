<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 测试1：日期偏移 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. 日期偏移测试"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/ed_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="输入日期 (yyyy-MM-dd)"
                android:text="2024-01-01"
                tools:ignore="Autofill,HardcodedText" />

            <EditText
                android:id="@+id/ed_days"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="偏移天数"
                android:inputType="numberSigned"
                android:text="30"
                tools:ignore="Autofill,HardcodedText" />

            <Button
                android:id="@+id/bt_test_offset_day"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="测试日期偏移"
                tools:ignore="HardcodedText" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#E0E0E0" />

            <!-- 测试2：格式转换 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="2. 时间格式转换"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/ed_datetime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="输入时间 (yyyyMMddHHmmss)"
                android:text="20240101143000"
                tools:ignore="Autofill,HardcodedText" />

            <Button
                android:id="@+id/bt_test_convert_format"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="测试格式转换"
                tools:ignore="HardcodedText" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#E0E0E0" />

            <!-- 测试3：时间戳 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="3. 时间戳转换"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/ed_date_for_timestamp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="输入日期时间 (yyyy-MM-dd HH:mm:ss)"
                android:text="2024-01-01 14:30:00"
                tools:ignore="Autofill,HardcodedText" />

            <Button
                android:id="@+id/bt_test_timestamp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="测试时间戳转换"
                tools:ignore="HardcodedText" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#E0E0E0" />

            <!-- 测试4：日期差值 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="4. 日期差值计算"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/ed_start_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="起始日期 (yyyy-MM-dd)"
                android:text="2024-01-01"
                tools:ignore="Autofill,HardcodedText" />

            <EditText
                android:id="@+id/ed_end_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="结束日期 (yyyy-MM-dd)"
                android:text="2024-12-31"
                tools:ignore="Autofill,HardcodedText" />

            <Button
                android:id="@+id/bt_test_date_diff"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="测试日期差值"
                tools:ignore="HardcodedText" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#E0E0E0" />

            <!-- 测试5：月份最大天数 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="5. 月份最大天数"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/ed_year"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="年份"
                android:inputType="number"
                android:text="2024"
                tools:ignore="Autofill,HardcodedText" />

            <EditText
                android:id="@+id/ed_month"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="月份 (1-12)"
                android:inputType="number"
                android:text="2"
                tools:ignore="Autofill,HardcodedText" />

            <Button
                android:id="@+id/bt_test_max_day"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="测试最大天数"
                tools:ignore="HardcodedText" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#E0E0E0" />

            <!-- 测试6：时区 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="6. 获取当前时区"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/bt_test_timezone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="获取时区"
                tools:ignore="HardcodedText" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#E0E0E0" />

            <!-- 测试7：月份偏移 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="7. 月份偏移测试"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/ed_date_for_month"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="输入日期 (yyyy-MM-dd)"
                android:text="2024-01-31"
                tools:ignore="Autofill,HardcodedText" />

            <EditText
                android:id="@+id/ed_months"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="偏移月数"
                android:inputType="numberSigned"
                android:text="3"
                tools:ignore="Autofill,HardcodedText" />

            <Button
                android:id="@+id/bt_test_offset_month"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="测试月份偏移"
                tools:ignore="HardcodedText" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- 结果显示区域 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:elevation="4dp">

        <TextView
            android:id="@+id/tv_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="100dp"
            android:padding="16dp"
            android:text="测试结果将显示在这里"
            android:textColor="#333333"
            android:textSize="14sp"
            tools:ignore="HardcodedText" />

    </androidx.cardview.widget.CardView>

</LinearLayout>
